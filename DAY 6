// 1.Write a program to print only numbers divisible by 5 using jumping stmt and looping stmt


package assignments;

public class JumpState {

	public static void main(String[] args) {
		// TODO Auto-generated method stub
		
		
		for(int i=1;i<=50;i++) {
			if(i%5!=0) {
				continue;
			}
			
			System.out.println("Number 5 is divisible : "+i);
		}

	}

}
