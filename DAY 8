package assignments;
 
// Method overloading occurs when multiple methods in the same class have the same name but different parameters (type, number, or order).


class  calu {
	 
	 void add(int a, int b){
		 System.out.println(" Adding 2 Number A and B is  : "+(a+b));
		 }
	 void multiply(int a, int b ,int c){
		 System.out.println(" Multiply  3 Number of a*b*c : "+(a*b*c));
	 }
	 void joiningwords(String name1,String name2) {
		 System.out.println(" Joining 2 words  is         : "+(name1+name2));
	 }
 }
public class Overloading {

	public static void main(String[] args) {
		// TODO Auto-generated method stub
		
		calu over=new calu();
		over.add(10, 20);
		over.multiply(2, 4, 3);
		over.joiningwords("PRAVEEN ", "V");
		
	}

}

